{
    "schemaVersion": 1,
    "id": "hybrid-birds",
    "version": "${version}",

    "name": "Hybrid Birds",
    "description": "A mod that adds new birds and improves upon existing ones",

    "authors": [
        "MysticKoko",
        "Aqua",
        "Andante",
        "Eggo"
    ],

    "contact": {
        "sources": "https://github.com/hybridlabs/hybrid-birds",
        "issues": "https://github.com/hybridlabs/hybrid-birds/issues"
    },

    "license": "ARR",
    "icon": "assets/hybrid-birds/icon.png",

    "environment": "*",
    "entrypoints": {
        "main": [
            {
                "value": "dev.hybridlabs.birds.HybridBirds",
                "adapter": "kotlin"
            }
        ],
        "client": [
            {
                "value": "dev.hybridlabs.birds.HybridBirdsClient",
                "adapter": "kotlin"
            }
        ],
        "fabric-datagen": [
            {
                "value": "dev.hybridlabs.birds.data.HybridBirdsDataGenerator",
                "adapter": "kotlin"
            }
        ],
        "preLaunch": [
            "com.llamalad7.mixinextras.MixinExtrasBootstrap::init"
        ]
    },

    "mixins": [
        "hybrid-birds.mixins.json",
        {
            "config": "hybrid-birds.client.mixins.json",
            "environment": "client"
        }
    ],

    "accessWidener": "hybrid-birds.accesswidener",

    "depends": {
        "minecraft": "~1.20.1",
        "java": ">=17",
        "fabric-language-kotlin": "*",
        "fabric-api": ">=0.92",
        "geckolib": ">=4.4"
    }
}
