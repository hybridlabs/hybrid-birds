{
    "schemaVersion": 1,
    "id": "hybrid_birds",
    "version": "${version}",

    "name": "Hybrid Birds",
  "description": "${description}",

    "authors": [
      "MysticKoko",
      "Aqua",
      "Andante",
      "Eggo",
      "Ragno",
      "murphy slaw",
      "AyaanDB"
    ],

  "contact": {
    "homepage": "https://github.com/hybridlabs/hybrid_birds",
    "sources": "https://github.com/hybridlabs/hybrid_birds",
    "issues": "https://github.com/hybridlabs/hybrid_birds/issues"
  },

    "license": "ARR",
    "icon": "assets/hybrid_birds/icon.png",

    "environment": "*",
    "entrypoints": {
        "main": [
            {
                "value": "dev.hybridlabs.birds.HybridBirds",
                "adapter": "kotlin"
            }
        ],
        "client": [
            {
                "value": "dev.hybridlabs.birds.HybridBirdsClient",
                "adapter": "kotlin"
            }
        ],
        "fabric-datagen": [
            {
                "value": "dev.hybridlabs.birds.data.HBDataGenerator",
                "adapter": "kotlin"
            }
        ],
        "preLaunch": [
            "com.llamalad7.mixinextras.MixinExtrasBootstrap::init"
        ]
    },

    "mixins": [
        "hybrid_birds.fabric.mixins.json"
    ],

    "accessWidener": "hybrid_birds.accesswidener",

    "depends": {
      "minecraft": "~1.21.1",
      "java": ">=21",
      "fabric-language-kotlin": "*",
      "fabric-api": ">=0.116",
      "geckolib": ">=4.8"
    }
}